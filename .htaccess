# Deny access to data directory (SQLite database)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^data/ - [F,L]
</IfModule>

# Deny access to config and db files directly
<FilesMatch "\.(sqlite|db|json)$">
    Require all denied
</FilesMatch>

# Block access to sensitive PHP files
<FilesMatch "^(config|db|auth)\.php$">
    Require all denied
</FilesMatch>
